#------------------------------------------------------------------------------
# Emscripten C compiler
#------------------------------------------------------------------------------
SUFFIXES   += .c

cc         := emcc
cARCH      :=
cDBUG      :=
cOPT       := -O2
cWARN      := -Wall


ifneq (,$(strip $(WM_COMPILE_OPTION)))
    sinclude $(DEFAULT_RULES)/c$(WM_COMPILE_OPTION)
endif

cFLAGS      = \
    $(cARCH) $(GFLAGS) $(cWARN) $(cOPT) $(cDBUG) \
    $(FOAM_EXTRA_CFLAGS) $(LIB_HEADER_DIRS)

ctoo        = $(WM_SCHEDULER) $(cc) $(cFLAGS) -c $< -o $@

LINK_LIBS   = $(cDBUG)
LINKLIBSO   = emar cr
LINKEXE     = $(cc) $(cARCH)

#------------------------------------------------------------------------------
